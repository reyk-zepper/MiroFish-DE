# ============================================================
# MiroFish-DE local-first example: Mac mini + Ollama + Neo4j
# ============================================================

# German defaults are built into the fork.

# ------------------------------------------------------------
# LLM: local Ollama OpenAI-compatible endpoint
# ------------------------------------------------------------
LLM_PROVIDER=local
LOCAL_LLM_API_KEY=ollama
# If the backend runs directly on the Mac, use http://localhost:11434/v1.
# If the backend runs in Docker/OrbStack, use http://host.docker.internal:11434/v1.
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434/v1
LOCAL_LLM_MODEL=qwen2.5:7b-instruct

# Optional stronger model for later manual experiments:
# LOCAL_LLM_MODEL=qwen2.5:14b-instruct

# ------------------------------------------------------------
# Graph memory: local Neo4j provider
# ------------------------------------------------------------
GRAPH_PROVIDER=graphiti_neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# ------------------------------------------------------------
# Embeddings: local Ollama model, reserved for the next Graphiti step
# ------------------------------------------------------------
EMBEDDING_PROVIDER=local
# If backend runs directly on the Mac, use http://localhost:11434/v1.
# If backend runs in Docker/OrbStack, use http://host.docker.internal:11434/v1.
LOCAL_EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
LOCAL_EMBEDDING_API_KEY=ollama
LOCAL_EMBEDDING_MODEL=nomic-embed-text

# ------------------------------------------------------------
# Optional legacy provider: Zep Cloud
# Only needed when GRAPH_PROVIDER=zep_cloud.
# ------------------------------------------------------------
# ZEP_API_KEY=your_zep_api_key_here

# ------------------------------------------------------------
# Cost/runtime safety defaults for local machines
# ------------------------------------------------------------
OASIS_DEFAULT_MAX_ROUNDS=20
REPORT_AGENT_MAX_TOOL_CALLS=5
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2

# Flask/dev
FLASK_DEBUG=True
