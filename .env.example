# ============================================================
# MiroFish-DE environment
# ============================================================

# Default UI / backend language is German.
# LLM APIs must be OpenAI-compatible.
# Choose one provider: local, openai, openrouter, custom
LLM_PROVIDER=local

# ------------------------------------------------------------
# Local model profile: Ollama or vLLM
# ------------------------------------------------------------
# Ollama example:
LOCAL_LLM_API_KEY=dummy
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=qwen2.5:14b

# vLLM example:
# LOCAL_LLM_API_KEY=dummy
# LOCAL_LLM_BASE_URL=http://localhost:8000/v1
# LOCAL_LLM_MODEL=Qwen/Qwen2.5-32B-Instruct

# ------------------------------------------------------------
# OpenAI API profile
# Note: a ChatGPT Pro subscription is not an API key.
# You need an OpenAI API key from https://platform.openai.com/
# ------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------
# OpenRouter profile
# ------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# ------------------------------------------------------------
# Custom OpenAI-compatible fallback profile
# Kept for compatibility with upstream MiroFish.
# ------------------------------------------------------------
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# ------------------------------------------------------------
# Graph memory provider
# MiroFish-DE defaults to local Neo4j. Zep Cloud is optional legacy mode.
# Choose one: graphiti_neo4j, zep_cloud
# ------------------------------------------------------------
GRAPH_PROVIDER=graphiti_neo4j

# Local Neo4j provider
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# Local embedding profile, reserved for Graphiti/semantic-search expansion
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_BASE_URL=http://localhost:11434/v1
LOCAL_EMBEDDING_API_KEY=ollama
LOCAL_EMBEDDING_MODEL=nomic-embed-text

# Optional Zep Cloud legacy mode. Only required when GRAPH_PROVIDER=zep_cloud.
# ZEP_API_KEY=your_zep_api_key_here

# ------------------------------------------------------------
# Cost/runtime safety defaults
# ------------------------------------------------------------
OASIS_DEFAULT_MAX_ROUNDS=10
REPORT_AGENT_MAX_TOOL_CALLS=5
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2

# Flask/dev
FLASK_DEBUG=True
